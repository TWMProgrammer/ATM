.vscode/**
.vscode-test/**
out/**
node_modules/**
# Astro formatter deps are externalized by esbuild (WASM parser stays lazy),
# so they must ship in the .vsix — re-include them after the blanket ignore.
!node_modules/@astrojs/compiler/**
!node_modules/sass-formatter/**
!node_modules/suf-log/**
src/**
!src/**/*.html
!src/**/*.css
!src/**/*.svg
!src/**/*.png
!src/**/*.json
!src/extensions/terminal-sound/
!src/extensions/terminal-sound/sound/
!src/extensions/terminal-sound/sound/**
!src/**/*.tmLanguage
.gitignore
.yarnrc
.prettierrc
.prettierignore
esbuild.js
vsc-extension-quickstart.md
**/tsconfig.json
**/eslint.config.mjs
**/*.map
**/*.ts
**/.vscode-test.*
package-lock.json
docs/**

# Voice TTS: no incluir modelos de voz en el .vsix (cada usuario los descarga con "Download Voice")
**/*.onnx
voices
piper

# gohitx
public/**
src/__test__/**
ARCHITECTURE.md
CONTRIBUTING.md
CODE_OF_CONDUCT.md
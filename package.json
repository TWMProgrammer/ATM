          "name": "Graph",
          "icon": "$(git-merge)"
        }
      ]
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "gitlab-panel",
          "title": "GitLab",
          "icon": "$(git-merge)"
        }
      ]
    }

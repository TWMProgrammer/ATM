{
  "name": "atm",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "1.9.6",
  "vsce": {
    "dependencies": false
  },
  "publisher": "bastndev",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Visualization",
    "Snippets",
    "Linters",
    "Formatters",
    "Other"
  ],
  "keywords": [
    "atm",
    "ghost",
    "fantasmita",
    "ai",
    "trae",
    "kiro",
    "error lens",
    "git blame",
    "env",
    "image preview",
    "screenshot",
    "pomodoro",
    "voice tts",
    "svg optimizer",
    "spell check",
    "todo",
    "markdown",
    "mdx",
    "translate",
    "productivity",
    "developer tools",
    "all in one",
    "multilanguage",
    "snippets",
    "lint",
    "cursor",
    "windsurf"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "homepage": "https://github.com/bastndev/ATM#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/bastndev/ATM"
  },
  "bugs": {
    "url": "https://github.com/bastndev/ATM/issues/new"
  },
  "author": {
    "name": "Gohit Bastian",
    "email": "bastndev@gohit.xyz",
    "url": "https://www.gohit.xyz/me"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/bastndev"
  },
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:dotenv",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:html",
    "onLanguage:css",
    "onLanguage:scss",
    "onLanguage:vue",
    "onLanguage:astro",
    "onLanguage:svelte",
    "onLanguage:json"
  ],
  "packageManager": "bun@1.3.4",
  "l10n": "./l10n",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "atm.compareCode.open",
        "title": "ATM: Compare Code",
        "icon": "$(activate-breakpoints)"
      },
      {
        "command": "atm.voiceTts.copyAndRead",
        "title": "ATM Voice TTS: Copy & Read"
      },
      {
        "command": "commentsCode.listAnnotations",
        "title": "ATM: List TODO / FIXME Annotations"
      },
      {
        "command": "atm.translate-doc.translateExtension",
        "title": "ATM: Translate",
        "icon": "$(globe)"
      },
      {
        "command": "atm.voiceTts.selectVoice",
        "title": "ATM Voice TTS: Select Voice",
        "icon": "$(globe)"
      },
      {
        "command": "atm.mdx.preview",
        "title": "ATM: Open MDX Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "git-better.copyHash",
        "title": "ATM Git: Copy Commit Hash"
      },
      {
        "command": "git-better.openGitHub",
        "title": "ATM Git: Open Commit on GitHub"
      },
      {
        "command": "git-better.toggleBlame",
        "title": "ATM Git: Toggle Inline Blame"
      },
      {
        "command": "atm.screenshotCode",
        "title": "ATM (📸) screenshot"
      },
      {
        "command": "atm.versionPackage.check",
        "title": "ATM: Check Package Versions",
        "icon": "$(cloud-download)"
      },
      {
        "command": "atm.versionPackage.updateAll",
        "title": "ATM: Update All Packages",
        "icon": "$(wand)"
      },
      {
        "command": "atm.svgBetter.optimize",
        "title": "ATM: Optimize SVG",
        "icon": "$(zap)"
      },
      {
        "command": "atm.copyTag.run",
        "title": "ATM Copy: Highlight Copied Text"
      },
      {
        "command": "atm.translate-doc.translateReleaseNotes",
        "title": "ATM: Translate Release Notes",
        "icon": "$(globe)"
      },
      {
        "command": "atm.dataId.showConsumption",
        "title": "ATM: Data AI",
        "icon": "$(sparkle-filled)"
      },
      {
        "command": "envLens.revealValue",
        "title": "Env Lens: Reveal Value"
      },
      {
        "command": "envLens.disableBlur",
        "title": "Env Lens: Reveal .env Values",
        "icon": "$(eye-closed)"
      },
      {
        "command": "envLens.enableBlur",
        "title": "Env Lens: Hide .env Values",
        "icon": "$(eye)"
      },
      {
        "command": "atm.lint.toggle",
        "title": "ATM Lint: Toggle Engine"
      },
      {
        "command": "atm.lint.revalidateOpenFiles",
        "title": "ATM Lint: Revalidate Open Files",
        "icon": "$(refresh)"
      },
      {
        "command": "atm.music.togglePlayPause",
        "title": "ATM Music: Play/Pause"
      },
      {
        "command": "atm.music.playRandomAM",
        "title": "ATM Music: Random AM Station"
      },
      {
        "command": "atm.translate.open",
        "title": "ATM: Translator",
        "icon": {
          "light": "src/extensions/21-atm-translate/assets/language.svg",
          "dark": "src/extensions/21-atm-translate/assets/language.svg"
        }
      },
      {
        "command": "atm.translate.setDeepLApiKey",
        "title": "ATM Translate: Set DeepL API Key",
        "icon": "$(key)"
      },
      {
        "command": "atm.translate.setGoogleCloudApiKey",
        "title": "ATM Translate: Set Google Cloud API Key",
        "icon": "$(key)"
      },
      {
        "command": "atm.translate.setLibreTranslateApiKey",
        "title": "ATM Translate: Set LibreTranslate API Key",
        "icon": "$(key)"
      },
      {
        "command": "atm.translate.clearApiKeys",
        "title": "ATM Translate: Clear Stored API Keys",
        "icon": "$(trash)"
      },
      {
        "command": "terminalSound.testSound",
        "title": "Terminal Sound: Test Sound"
      },
      {
        "command": "terminalSound.toggle",
        "title": "Terminal Sound: Toggle Enable/Disable"
      },
      {
        "command": "tailwind-css.toggleAutoFold",
        "title": "Tailwind CSS: Toggle Fold/Unfold"
      },
      {
        "command": "tailwind-css.toggleEnabled",
        "title": "Tailwind CSS: Enable/Disable"
      },
      {
        "command": "atm.bracketLynx.toggle",
        "title": "Bracket Lynx: Toggle",
        "icon": "$(bracket-dot)"
      },
      {
        "command": "atm.npmRun.release",
        "title": "ATM: Release NPM Package",
        "icon": "$(rocket)"
      },
      {
        "command": "atm.npmRun.releaseMajor",
        "title": "ATM: Release NPM Package (major)",
        "icon": "$(rocket)"
      },
      {
        "command": "atm.npmRun.releaseMinor",
        "title": "ATM: Release NPM Package (minor)",
        "icon": "$(rocket)"
      },
      {
        "command": "atm.npmRun.releaseBeta",
        "title": "ATM: Release NPM Package (beta)",
        "icon": "$(beaker)"
      },
      {
        "command": "atm.npmRun.refresh",
        "title": "ATM: NPM Release — Refresh Status"
      },
      {
        "command": "atm.browser.open",
        "title": "ATM: Open Browser",
        "icon": "$(globe)"
      },
      {
        "command": "atm.browser.newTab",
        "title": "ATM: Browser — New Tab",
        "icon": "$(add)"
      },
      {
        "command": "atm.goLive.start",
        "title": "ATM: Open with Live Server (Go Live)",
        "icon": "$(broadcast)"
      },
      {
        "command": "atm.goLive.stop",
        "title": "ATM: Stop Live Server",
        "icon": "$(circle-slash)"
      },
      {
        "command": "atm.goLive.changeWorkspace",
        "title": "ATM: Live Server — Change Workspace Root"
      },
      {
        "command": "atm.runDev.start",
        "title": "ATM: Run Dev Server",
        "icon": "$(play)"
      },
      {
        "command": "atm.runDev.restart",
        "title": "ATM: Restart Dev Server",
        "icon": "$(refresh)"
      },
      {
        "command": "atm.runDev.stop",
        "title": "ATM: Stop Dev Server",
        "icon": "$(debug-stop)"
      },
      {
        "command": "atm.runDev.openBrowser",
        "title": "ATM: Run Dev — Open in Browser",
        "icon": "$(globe)"
      },
      {
        "command": "atm.formatter.formatDocument",
        "title": "ATM Formatter: Format Document",
        "icon": "$(paint)"
      },
      {
        "command": "atm.formatter.forceFormat",
        "title": "ATM Formatter: Force Format (ignore .atmignore)",
        "icon": "$(paint)"
      },
      {
        "command": "atm.formatter.showOutput",
        "title": "ATM Formatter: Show Output"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "ATM – Image Preview",
      "properties": {
        "atm.goLive.port": {
          "type": "number",
          "default": 3222,
          "minimum": 0,
          "maximum": 65535,
          "description": "Port for ATM Live Server (Go Live). If it is busy, the next free port is used automatically."
        },
        "atm.goLive.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host interface Go Live binds to. Use 0.0.0.0 to expose the server on your LAN."
        },
        "atm.goLive.root": {
          "type": "string",
          "default": "",
          "description": "Workspace-relative sub-folder to serve as the site root. Empty serves the workspace root."
        },
        "atm.goLive.openIn": {
          "type": "string",
          "enum": [
            "external",
            "simpleBrowser",
            "none"
          ],
          "enumDescriptions": [
            "Open the served page in your default system browser.",
            "Open the served page inside VS Code's Simple Browser.",
            "Start the server without opening any browser."
          ],
          "default": "external",
          "description": "Where Go Live opens the page when the server starts."
        },
        "atm.goLive.wait": {
          "type": "number",
          "default": 100,
          "minimum": 0,
          "description": "Debounce (ms) after a file change before Go Live reloads the browser."
        },
        "atm.goLive.fullReload": {
          "type": "boolean",
          "default": false,
          "description": "Reload the whole page on CSS changes instead of hot-swapping stylesheets in place."
        },
        "atm.goLive.spaFile": {
          "type": "string",
          "default": "",
          "description": "Root-relative file served for navigation 404s (single-page-app fallback, e.g. index.html)."
        },
        "atm.goLive.cors": {
          "type": "boolean",
          "default": false,
          "description": "Add a permissive 'Access-Control-Allow-Origin: *' header to every response."
        },
        "atm.goLive.showOnStatusbar": {
          "type": "boolean",
          "default": true,
          "description": "Show the Go Live control in the status bar."
        },
        "atm.goLive.ignoreFiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".vscode/**",
            ".git/**",
            "node_modules/**",
            "**/*.scss",
            "**/*.sass",
            "**/*.ts"
          ],
          "description": "Glob patterns whose changes do not trigger a live reload."
        },
        "atm.goLive.headers": {
          "type": "object",
          "default": {},
          "description": "Extra HTTP response headers merged into every Go Live response."
        },
        "atm.goLive.mount": {
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "string"
            }
          },
          "default": [],
          "description": "Mount extra directories under URL prefixes, e.g. [[\"/vendor\", \"./node_modules\"]]."
        },
        "atm.goLive.https": {
          "type": "object",
          "properties": {
            "enable": {
              "type": "boolean",
              "default": false
            },
            "cert": {
              "type": "string",
              "default": ""
            },
            "key": {
              "type": "string",
              "default": ""
            },
            "passphrase": {
              "type": "string",
              "default": ""
            }
          },
          "default": {
            "enable": false,
            "cert": "",
            "key": "",
            "passphrase": ""
          },
          "additionalProperties": false,
          "description": "Serve over HTTPS using the given certificate and key file paths."
        },
        "atm.goLive.multiRootWorkspaceName": {
          "type": "string",
          "default": "",
          "description": "Remembered workspace folder used as the Go Live root in multi-root workspaces."
        },
        "atm.runDev.packageManager": {
          "type": "string",
          "enum": [
            "auto",
            "bun",
            "npm",
            "pnpm",
            "yarn"
          ],
          "default": "auto",
          "description": "Package manager used to run the dev script. Auto-detects from the packageManager field or lockfile."
        },
        "atm.runDev.script": {
          "type": "string",
          "default": "",
          "description": "Script to run (e.g. dev, start). Empty auto-detects the framework's preferred dev/start script."
        },
        "atm.runDev.openBrowser": {
          "type": "string",
          "enum": [
            "external",
            "simpleBrowser",
            "none"
          ],
          "enumDescriptions": [
            "Open the dev URL in your default system browser.",
            "Open the dev URL inside VS Code's Simple Browser.",
            "Never open a browser automatically."
          ],
          "default": "external",
          "description": "Where Run Dev opens the detected dev-server URL (ignored for mobile targets like Expo/React Native/Lynx)."
        },
        "atm.runDev.autoOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the browser once the dev server prints its local URL."
        },
        "atm.runDev.autoRestartOnConfigChange": {
          "type": "boolean",
          "default": false,
          "description": "Restart the dev server automatically when a watched config or .env file changes (files frameworks usually don't hot-reload)."
        },
        "atm.runDev.configWatchGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.config.{js,ts,mjs,cjs,mts}",
            ".env",
            ".env.*"
          ],
          "description": "Glob patterns (relative to the project) watched when autoRestartOnConfigChange is on."
        },
        "atm.runDev.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra arguments appended to the dev script (e.g. [\"--host\"])."
        },
        "atm.runDev.env": {
          "type": "object",
          "default": {},
          "description": "Extra environment variables for the dev-server process."
        },
        "atm.runDev.revealTerminalOnStart": {
          "type": "boolean",
          "default": false,
          "description": "Reveal the dev-server terminal panel when it starts (without stealing editor focus). When false (default), it stays hidden — the status bar shows starting/running/failed, and the terminal only auto-opens (with focus) if the dev server exits with an error."
        },
        "atm.runDev.showOnStatusbar": {
          "type": "boolean",
          "default": true,
          "description": "Show the Run Dev control in the status bar."
        },
        "atm.browser.executablePath": {
          "type": "string",
          "default": "",
          "description": "Path to a Chromium-based browser (Chrome, Edge, Brave, Chromium, Vivaldi) used by ATM Browser. Leave empty to auto-detect."
        },
        "atm.browser.startUrl": {
          "type": "string",
          "default": "",
          "description": "URL opened in new ATM Browser tabs. Leave empty for a blank page with the URL bar focused."
        },
        "atm.browser.searchEngine": {
          "type": "string",
          "enum": [
            "bing",
            "google",
            "duckduckgo",
            "none"
          ],
          "default": "bing",
          "description": "Search engine used when the ATM Browser URL bar input is not a URL."
        },
        "atm.browser.quality": {
          "type": "number",
          "default": 80,
          "minimum": 10,
          "maximum": 100,
          "description": "JPEG quality of the ATM Browser page stream (higher = sharper, more CPU)."
        },
        "atm.image.preview.showImagePreviewOnGutter": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Show image thumbnail in the editor gutter"
        },
        "atm.image.preview.showUnderline": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Underline recognized image URLs"
        },
        "atm.image.preview.imagePreviewMaxHeight": {
          "type": "number",
          "default": 100,
          "scope": "resource",
          "description": "Maximum height (px) of the hover image preview"
        },
        "atm.image.preview.imagePreviewMaxWidth": {
          "type": "number",
          "default": -1,
          "scope": "resource",
          "description": "Maximum width (px) of the hover preview (overrides maxHeight when > 0)"
        },
        "atm.image.preview.sourceFolder": {
          "type": "string",
          "default": "src",
          "scope": "resource",
          "description": "Additional folder to consider when resolving relative URLs"
        },
        "atm.image.preview.sourceFolders": {
          "type": "array",
          "default": [
            "static",
            "public"
          ],
          "scope": "resource",
          "description": "Additional folders to consider when resolving relative URLs"
        },
        "atm.image.preview.excludeFilePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".env*",
            ".envrc",
            ".secrets",
            ".secret",
            ".credentials",
            ".npmrc",
            ".pypirc",
            ".netrc",
            ".git-credentials"
          ],
          "scope": "resource",
          "description": "File name/path patterns where image preview is disabled (no gutter icon and no hover). Supports * and ? wildcards."
        },
        "atm.image.preview.currentColorForSVG": {
          "type": "string",
          "default": "white",
          "scope": "resource",
          "description": "Default currentColor for SVG previews"
        },
        "atm.voiceTts.voice": {
          "type": "string",
          "default": "en_US-hfc_female-medium",
          "description": "Voice model for ATM Voice TTS. Use Select Voice or Download Voice to change."
        },
        "atm.codeSpell.customWords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Array of custom words added to the ATM Code-Spell dictionary."
        },
        "atm.lint.enableSuggestions": {
          "type": "boolean",
          "default": true,
          "description": "Enable suggestion-based Lint Quick Fixes (for example, == to ===)."
        },
        "atm.lint.showOperationalWarnings": {
          "type": "boolean",
          "default": false,
          "description": "Show operational ESLint warnings as diagnostics (for example, file ignored because no matching configuration was supplied)."
        },
        "atm.translate.provider": {
          "type": "string",
          "enum": [
            "auto",
            "googleUnofficial",
            "myMemory",
            "libreTranslate",
            "deepL",
            "googleCloud"
          ],
          "default": "auto",
          "scope": "application",
          "description": "Primary ATM Translate provider. Auto tries configured fallbacks in order."
        },
        "atm.translate.fallbackProviders": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "googleUnofficial",
              "myMemory",
              "libreTranslate",
              "deepL",
              "googleCloud"
            ]
          },
          "default": [
            "googleUnofficial",
            "myMemory",
            "libreTranslate",
            "deepL",
            "googleCloud"
          ],
          "scope": "application",
          "description": "Fallback order used by ATM Translate when the primary provider fails or is rate-limited."
        },
        "atm.translate.spellcheckProvider": {
          "type": "string",
          "enum": [
            "auto",
            "googleUnofficial"
          ],
          "default": "auto",
          "scope": "application",
          "description": "Provider used by ATM Translate Fix Spelling. Auto uses local corrections first, then Google Translate when enabled."
        },
        "atm.translate.googleUnofficialEnabled": {
          "type": "boolean",
          "default": true,
          "scope": "application",
          "description": "Allow the unofficial Google Translate fallback. Disable this when you want only official or local providers."
        },
        "atm.translate.myMemoryEmail": {
          "type": "string",
          "default": "",
          "scope": "application",
          "description": "Optional contact email sent to MyMemory to raise the free daily quota for public translations."
        },
        "atm.translate.libreTranslateUrl": {
          "type": "string",
          "default": "http://127.0.0.1:5000",
          "scope": "application",
          "description": "Base URL for LibreTranslate. Use the Set LibreTranslate API Key command if the instance requires a key."
        },
        "atm.translate.deepLEndpoint": {
          "type": "string",
          "enum": [
            "free",
            "pro"
          ],
          "default": "free",
          "scope": "application",
          "description": "DeepL endpoint type used by ATM Translate after saving a DeepL API key."
        },
        "atm.colorBgTag.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable native high-performance HTML Tag background coloration."
        },
        "atm.copyTag.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable visual highlight when copying text."
        },
        "atm.copyTag.backgroundColor": {
          "type": "string",
          "default": "rgba(45, 212, 191, 0.3)",
          "description": "Background color for the copied text highlight."
        },
        "atm.copyTag.foregroundColor": {
          "type": "string",
          "description": "Optional text foreground color when highlighted."
        },
        "atm.copyTag.timeout": {
          "type": "number",
          "default": 250,
          "minimum": 50,
          "maximum": 2000,
          "description": "Duration in milliseconds the highlight remains visible."
        },
        "atm.envLens.renderMode": {
          "type": "string",
          "enum": [
            "blur",
            "mask"
          ],
          "default": "blur",
          "description": "How ENV values are hidden in .env files: blur keeps shape visible, mask hides text fully with bullets."
        },
        "atm.envLens.revealDurationMs": {
          "type": "number",
          "default": 4000,
          "minimum": 1000,
          "maximum": 15000,
          "description": "How long (ms) a single revealed env value stays visible before being hidden again."
        },
        "atm.envLens.enableHoverReveal": {
          "type": "boolean",
          "default": true,
          "description": "Enable reveal links in hovers for individual env values."
        },
        "atm.envLens.autoEnableBlurOnFocusOut": {
          "type": "boolean",
          "default": true,
          "description": "Automatically re-enable blur when leaving a .env file."
        },
        "atm.envLens.ultraSecureMode": {
          "type": "boolean",
          "default": false,
          "description": "Disable all hover reveal actions and force hidden env values for maximum safety."
        },
        "atm.youtubeApiKey": {
          "type": "string",
          "default": "",
          "description": "YouTube V3 API Key for ATM Music Search"
        },
        "tailwind-css.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Tailwind CSS completely."
        },
        "terminalSound.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable terminal error sound notifications"
        },
        "terminalSound.debounceMs": {
          "type": "number",
          "default": 1500,
          "minimum": 0,
          "maximum": 1e4,
          "description": "Debounce time in milliseconds (per terminal)"
        },
        "terminalSound.customSoundPath": {
          "type": "string",
          "default": "",
          "description": "Path to custom sound file (MP3, WAV, OGG). Leave empty to use default sound."
        },
        "terminalSound.volume": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 1,
          "description": "Volume level (0.0 to 1.0)"
        },
        "atm.bracketLynx.globalEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Bracket Lynx decorations globally."
        },
        "atm.formatter.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable ATM Formatter for TypeScript, TSX, and CSS files."
        },
        "atm.formatter.printWidth": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "description": "Maximum line width that Prettier will wrap to."
        },
        "atm.formatter.tabWidth": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "description": "Number of spaces per indentation level."
        },
        "atm.formatter.useTabs": {
          "type": "boolean",
          "default": false,
          "description": "Indent with tabs instead of spaces."
        },
        "atm.formatter.semi": {
          "type": "boolean",
          "default": true,
          "description": "Add semicolons to the end of statements."
        },
        "atm.formatter.singleQuote": {
          "type": "boolean",
          "default": true,
          "description": "Use single quotes instead of double quotes."
        },
        "atm.formatter.trailingComma": {
          "type": "string",
          "enum": ["none", "es5", "all"],
          "default": "all",
          "enumDescriptions": [
            "No trailing commas.",
            "Trailing commas where valid in ES5 (objects, arrays).",
            "Trailing commas wherever possible."
          ],
          "description": "Controls trailing commas in multi-line constructs."
        },
        "atm.formatter.bracketSpacing": {
          "type": "boolean",
          "default": true,
          "description": "Add spaces between brackets in object literals."
        },
        "atm.formatter.bracketSameLine": {
          "type": "boolean",
          "default": false,
          "description": "Put the closing > of multi-line JSX/HTML on the same line as the last line."
        },
        "atm.formatter.arrowParens": {
          "type": "string",
          "enum": ["avoid", "always"],
          "default": "always",
          "enumDescriptions": ["Omit parens for single arrow function parameters.", "Always include parens."],
          "description": "Parentheses around single arrow function parameter."
        },
        "atm.formatter.endOfLine": {
          "type": "string",
          "enum": ["auto", "lf", "crlf", "cr"],
          "default": "lf",
          "enumDescriptions": ["Maintain existing line endings.", "Force LF.", "Force CRLF.", "Force CR (old Mac)."],
          "description": "Line ending style for formatted output."
        },
        "atm.formatter.requireConfig": {
          "type": "boolean",
          "default": false,
          "description": "Only format files when a Prettier config file (.prettierrc or package.json) is found."
        },
        "atm.formatter.ignorePath": {
          "type": "string",
          "default": ".atmignore",
          "description": "Path to the ignore file (relative to the workspace root). Lists files that ATM Formatter should skip."
        }
      }
    },
    "grammars": [
      {
        "language": "mdx",
        "scopeName": "source.mdx",
        "path": "./src/extensions/13-markdown-mdx/syntaxes/source.mdx.tmLanguage",
        "embeddedLanguages": {
          "meta.embedded.c": "c",
          "meta.embedded.cpp": "cpp",
          "meta.embedded.cs": "csharp",
          "meta.embedded.css": "css",
          "meta.embedded.diff": "diff",
          "meta.embedded.go": "go",
          "meta.embedded.graphql": "graphql",
          "meta.embedded.html": "html",
          "meta.embedded.ini": "ini",
          "meta.embedded.java": "java",
          "meta.embedded.js": "javascriptreact",
          "meta.embedded.json": "json",
          "meta.embedded.kotlin": "kotlin",
          "meta.embedded.less": "less",
          "meta.embedded.lua": "lua",
          "meta.embedded.makefile": "makefile",
          "meta.embedded.md": "markdown",
          "meta.embedded.mdx": "mdx",
          "meta.embedded.objc": "objective-c",
          "meta.embedded.perl": "perl",
          "meta.embedded.php": "php",
          "meta.embedded.python": "python",
          "meta.embedded.r": "r",
          "meta.embedded.ruby": "ruby",
          "meta.embedded.rust": "rust",
          "meta.embedded.scss": "scss",
          "meta.embedded.shell": "shellscript",
          "meta.embedded.sql": "sql",
          "meta.embedded.svg": "xml",
          "meta.embedded.swift": "swift",
          "meta.embedded.toml": "toml",
          "meta.embedded.ts": "typescriptreact",
          "meta.embedded.tsx": "typescriptreact",
          "meta.embedded.vbnet": "vb",
          "meta.embedded.xml": "xml",
          "meta.embedded.yaml": "yaml"
        }
      },
      {
        "scopeName": "source.markdown.mdx.codeblock",
        "path": "./src/extensions/13-markdown-mdx/syntaxes/mdx.markdown.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.mdx": "mdx"
        }
      }
    ],
    "keybindings": [
      {
        "command": "atm.compareCode.open",
        "key": "alt+shift+\\",
        "mac": "alt+shift+\\"
      },
      {
        "command": "atm.browser.open",
        "key": "alt+shift+b",
        "mac": "alt+shift+b"
      },
      {
        "command": "-workbench.action.gotoLine",
        "key": "ctrl+g",
        "mac": "ctrl+g"
      },
      {
        "command": "atm.voiceTts.copyAndRead",
        "key": "shift+space",
        "mac": "cmd+shift+space"
      },
      {
        "command": "atm.voiceTts.selectVoice",
        "key": "shift+alt+space",
        "mac": "cmd+shift+alt+space"
      },
      {
        "command": "atm.translate-doc.translateExtension",
        "key": "ctrl+shift+space",
        "mac": "cmd+shift+space",
        "when": "activeEditor == 'workbench.editor.extension'"
      },
      {
        "command": "atm.mdx.preview",
        "key": "shift+alt+m",
        "mac": "shift+alt+m",
        "when": "editorLangId == mdx"
      },
      {
        "command": "atm.copyTag.run",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "editorTextFocus"
      },
      {
        "command": "atm.translate-doc.translateReleaseNotes",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "atm.releaseNotes.active"
      },
      {
        "command": "atm.music.togglePlayPause",
        "key": "ctrl+shift+space",
        "mac": "cmd+shift+space"
      },
      {
        "command": "atm.music.playRandomAM",
        "key": "alt+r",
        "mac": "alt+r"
      },
      {
        "command": "atm.goLive.start",
        "key": "alt+l alt+o",
        "mac": "cmd+l cmd+o"
      },
      {
        "command": "atm.goLive.stop",
        "key": "alt+l alt+c",
        "mac": "cmd+l cmd+c"
      },
      {
        "command": "atm.runDev.start",
        "key": "alt+g",
        "mac": "alt+g"
      },
      {
        "command": "atm.runDev.restart",
        "key": "ctrl+g",
        "mac": "ctrl+g"
      },
      {
        "command": "atm.runDev.stop",
        "key": "ctrl+alt+g",
        "mac": "ctrl+alt+g"
      }
    ],
    "languages": [
      {
        "id": "mdx",
        "aliases": [
          "MDX"
        ],
        "extensions": [
          ".mdx"
        ],
        "configuration": "./src/extensions/13-markdown-mdx/syntaxes/language-configuration.json"
      }
    ],
    "markdown.markdownItPlugins": true,
    "markdown.previewScripts": [
      "./dist/mermaidPreview.js"
    ],
    "markdown.previewStyles": [
      "./src/extensions/12-markdown-md/ui/checkboxes.css"
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "atm.dataId.showConsumption",
          "when": "atm.isAntigravity"
        }
      ],
      "editor/context": [
        {
          "command": "atm.screenshotCode",
          "group": "1_modification",
          "when": "editorHasSelection"
        },
        {
          "command": "atm.translate-doc.translateReleaseNotes",
          "group": "1_modification",
          "when": "atm.releaseNotes.active"
        },
        {
          "command": "atm.goLive.start",
          "group": "navigation@99",
          "when": "resourceExtname == .html || resourceExtname == .htm || resourceExtname == .xhtml || resourceExtname == .svg"
        }
      ],
      "explorer/context": [
        {
          "command": "atm.goLive.start",
          "group": "navigation@-1",
          "when": "resourceExtname == .html || resourceExtname == .htm || resourceExtname == .xhtml || resourceExtname == .svg"
        }
      ],
      "editor/title": [
        {
          "command": "atm.compareCode.open",
          "group": "navigation@3",
          "when": "resourceScheme == file"
        },
        {
          "command": "atm.translate.open",
          "group": "navigation@0",
          "when": "activeEditor != 'workbench.editor.extension' && resourceExtname != .md && resourceExtname != .json"
        },
        {
          "command": "atm.translate-doc.translateExtension",
          "group": "navigation",
          "when": "activeEditor == 'workbench.editor.extension'"
        },
        {
          "command": "atm.mdx.preview",
          "group": "navigation",
          "when": "editorLangId == mdx"
        },
        {
          "command": "atm.versionPackage.check",
          "group": "navigation@1",
          "when": "resourceFilename == package.json"
        },
        {
          "command": "atm.versionPackage.updateAll",
          "group": "navigation@2",
          "when": "resourceFilename == package.json && atm.versionPackage.hasUpdates"
        },
        {
          "command": "atm.svgBetter.optimize",
          "group": "navigation",
          "when": "resourceExtname == .svg"
        },
        {
          "command": "atm.translate-doc.translateReleaseNotes",
          "group": "navigation",
          "when": "atm.releaseNotes.active"
        },
        {
          "command": "envLens.disableBlur",
          "group": "navigation@50",
          "when": "envLens.isEnvFile && envLens.blurEnabled"
        },
        {
          "command": "envLens.enableBlur",
          "group": "navigation@50",
          "when": "envLens.isEnvFile && !envLens.blurEnabled"
        },
        {
          "command": "atm.bracketLynx.toggle",
          "group": "navigation@51",
          "when": "editorLangId == javascript || editorLangId == typescript || editorLangId == javascriptreact || editorLangId == typescriptreact || editorLangId == html || editorLangId == css || editorLangId == scss || editorLangId == vue || editorLangId == astro || editorLangId == svelte || resourceFilename == package.json"
        }
      ],
      "extension/context": [
        {
          "command": "atm.translate-doc.translateExtension",
          "group": "1_modification"
        }
      ]
    },
    "problemMatchers": [
      {
        "name": "esbuild",
        "label": "esbuild problem matcher",
        "severity": "error",
        "applyTo": "closedDocuments",
        "source": "esbuild",
        "fileLocation": "relative",
        "pattern": [
          {
            "regexp": "^[✘▲] \\[([A-Z]+)\\] (.+)",
            "severity": 1,
            "message": 2
          },
          {
            "regexp": "^(?:\\t| {4})(?!\\s)([^:]+)(?::([0-9]+))?(?::([0-9]+))?:$",
            "file": 1,
            "line": 2,
            "column": 3
          }
        ]
      },
      {
        "name": "esbuild-watch",
        "base": "$esbuild",
        "label": "esbuild --watch problem matcher",
        "severity": "error",
        "applyTo": "closedDocuments",
        "source": "esbuild",
        "fileLocation": "relative",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "\\[watch\\] build started"
          },
          "endsPattern": {
            "regexp": "\\[watch\\] build finished"
          }
        }
      },
      {
        "name": "esbuild-0.13",
        "label": "esbuild <0.14 problem matcher",
        "severity": "error",
        "applyTo": "closedDocuments",
        "source": "esbuild",
        "fileLocation": "relative",
        "pattern": [
          {
            "regexp": "> (.*?):([0-9]+):([0-9]+): (warning|error): (.+)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "message": 5
          }
        ]
      },
      {
        "name": "esbuild-0.13-watch",
        "base": "$esbuild-0.13",
        "label": "esbuild <0.14 --watch problem matcher",
        "severity": "error",
        "applyTo": "closedDocuments",
        "source": "esbuild",
        "fileLocation": "relative",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "\\[watch\\] build started"
          },
          "endsPattern": {
            "regexp": "\\[watch\\] build finished"
          }
        }
      }
    ],
    "snippets": [
      {
        "language": "markdown",
        "path": "./src/extensions/12-markdown-md/snippets/markdown.json"
      }
    ],
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "atm-yt-music-view",
          "name": "ATM :: Radio/Music · Pomodoro · Data",
          "icon": "$(music)"
        }
